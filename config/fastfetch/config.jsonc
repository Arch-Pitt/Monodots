{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/logos/logo.txt",
    "padding": {
      "top": 1,
      "right": 3
    }
  },
  "display": {
    "separator": " ▸ "
  },
  "modules": [
    "break",
    {
      "type": "os",
      "key": ""
    },
    {
      "type": "kernel",
      "key": ""
    },
    {
      "type": "wm",
      "key": ""
    },
    {
      "type": "packages",
      "key": ""
    },
    {
      "type": "memory",
      "key": ""
    },
    {
      "type": "host",
      "key": ""
    },
    {
      "type": "cpu",
      "key": ""
    },
    {
      "type": "gpu",
      "key": ""
    },
    {
      "type": "swap",
      "key": ""
    },
    {
      "type": "battery",
      "key": ""
    },
    {
      "type": "uptime",
      "key": ""
    },
    "break",
    {
      "type": "colors",
      "symbol": "circle",
      "block": {
        "width": 5
      }
    },
    "break"
  ]
}
